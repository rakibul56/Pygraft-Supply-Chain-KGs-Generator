    rdfs:domain sc:HarvestBatch ;
    rdfs:range sc:Shipment ;
    owl:inverseOf sc:carriesBatch .

sc:ownedBy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain sc:Facility ;
    rdfs:range sc:Organization ;
    owl:inverseOf sc:ownsFacility .

