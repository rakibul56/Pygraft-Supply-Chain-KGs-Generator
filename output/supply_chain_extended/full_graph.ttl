sc:Grower a owl:Class ;
    rdfs:subClassOf sc:Organization ;
    owl:disjointWith sc:LogisticsProvider,
        sc:Retailer .

sc:ProcessingPlant a owl:Class ;
    rdfs:subClassOf sc:Facility .

sc:LogisticsProvider a owl:Class ;
    rdfs:subClassOf sc:Organization ;
    owl:disjointWith sc:Grower,
        sc:Retailer .

sc:Supplier a owl:Class ;
    rdfs:subClassOf sc:Organization .

sc:Distributor a owl:Class ;
    rdfs:subClassOf sc:Organization .

sc:Farm a owl:Class ;
    rdfs:subClassOf sc:Facility ;
    owl:disjointWith sc:Mill .

sc:Mill a owl:Class ;
    rdfs:subClassOf sc:Facility ;
    owl:disjointWith sc:Farm .

sc:Manufacturer a owl:Class ;
    rdfs:subClassOf sc:Organization .

sc:Regulator a owl:Class ;
    rdfs:subClassOf sc:Organization .

sc:DistributionCenter a owl:Class ;
    rdfs:subClassOf sc:Facility .

sc:CertificationBody a owl:Class ;
    rdfs:subClassOf sc:Organization .

sc:HarvestBatch a owl:Class ;
    rdfs:subClassOf sc:MaterialLot ;
    owl:disjointWith sc:Shipment .

sc:QualityLab a owl:Class ;
    rdfs:subClassOf sc:Facility .

sc:Warehouse a owl:Class ;
    rdfs:subClassOf sc:Facility .

sc:Retailer a owl:Class ;
    rdfs:subClassOf sc:Organization ;
    owl:disjointWith sc:Grower,
        sc:LogisticsProvider .

sc:Port a owl:Class ;
    rdfs:subClassOf sc:Facility .

sc:RetailStore a owl:Class ;
    rdfs:subClassOf sc:Facility .

sc:Product a owl:Class ;
    rdfs:subClassOf sc:Entity ;
    owl:disjointWith sc:Facility,
        sc:MaterialLot,
        sc:Organization,
        sc:Shipment,
        sc:TransportVehicle .

sc:TransportVehicle a owl:Class ;
    rdfs:subClassOf sc:Entity ;
    owl:disjointWith sc:Facility,
        sc:MaterialLot,
        sc:Organization,
        sc:Product,
        sc:Shipment .

sc:ProductBatch a owl:Class ;
    rdfs:subClassOf sc:MaterialLot ;
    owl:disjointWith sc:Shipment .

sc:Shipment a owl:Class ;
    rdfs:subClassOf sc:Entity ;
    owl:disjointWith sc:Facility,
        sc:HarvestBatch,
        sc:MaterialLot,
        sc:Organization,
        sc:Product,
        sc:ProductBatch,
        sc:TransportVehicle .

sc:MaterialLot a owl:Class ;
    rdfs:subClassOf sc:Entity ;
    owl:disjointWith sc:Facility,
        sc:Organization,
        sc:Product,
        sc:Shipment,
        sc:TransportVehicle .

sc:Facility a owl:Class ;
    rdfs:subClassOf sc:Entity ;
    owl:disjointWith sc:MaterialLot,
        sc:Organization,
        sc:Product,
        sc:Shipment,
        sc:TransportVehicle .

sc:Organization a owl:Class ;
    rdfs:subClassOf sc:Entity ;
    owl:disjointWith sc:Facility,
        sc:MaterialLot,
        sc:Product,
        sc:Shipment,
        sc:TransportVehicle .

