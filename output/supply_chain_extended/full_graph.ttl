sc:carriesBatch a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain sc:Shipment ;
    rdfs:range sc:MaterialLot ;
    owl:inverseOf sc:includedInShipment .

sc:includedInShipment a owl:ObjectProperty ;
    rdfs:domain sc:MaterialLot ;
    rdfs:range sc:Shipment ;
    owl:inverseOf sc:carriesBatch .

sc:ownedBy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain sc:Facility ;
    rdfs:range sc:Organization ;
    owl:inverseOf sc:ownsFacility .

sc:shippedBy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain sc:Shipment ;
    rdfs:range sc:LogisticsProvider .

