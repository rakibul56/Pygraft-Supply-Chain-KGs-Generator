        owl:FunctionalProperty ;
    rdfs:domain sc:HarvestBatch ;
    rdfs:range xsd:string .

sc:cropType a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:domain sc:HarvestBatch ;
    rdfs:range xsd:string .

sc:harvestDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:domain sc:HarvestBatch ;
    rdfs:range xsd:dateTime .

sc:harvestWeightKg a owl:DatatypeProperty ;
    rdfs:domain sc:HarvestBatch ;
    rdfs:range xsd:decimal .

sc:harvestedFrom a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain sc:HarvestBatch ;
    rdfs:range sc:Farm .

sc:harvestsBatch a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain sc:Grower ;
    rdfs:range sc:HarvestBatch .

sc:managesFarm a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain sc:Grower ;
    rdfs:range sc:Farm ;
    rdfs:subPropertyOf sc:ownsFacility .

sc:operatesMill a owl:ObjectProperty ;
    rdfs:domain sc:Organization ;
    rdfs:range sc:Mill ;
    rdfs:subPropertyOf sc:ownsFacility .

