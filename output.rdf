sc:Shipment a owl:Class ;
    rdfs:subClassOf sc:Entity ;
    owl:disjointWith sc:Facility,
        sc:HarvestBatch,
        sc:MaterialLot,
        sc:Organization .

sc:Mill a owl:Class ;
    rdfs:subClassOf sc:Facility ;
    owl:disjointWith sc:Farm .

sc:MaterialLot a owl:Class ;
    rdfs:subClassOf sc:Entity ;
    owl:disjointWith sc:Facility,
        sc:Organization,
        sc:Shipment .

sc:HarvestBatch a owl:Class ;
    rdfs:subClassOf sc:MaterialLot ;
    owl:disjointWith sc:Shipment .

sc:Farm a owl:Class ;
    rdfs:subClassOf sc:Facility ;
    owl:disjointWith sc:Mill .

sc:Grower a owl:Class ;
    rdfs:subClassOf sc:Organization ;
    owl:disjointWith sc:LogisticsProvider,
        sc:Retailer .

sc:LogisticsProvider a owl:Class ;
    rdfs:subClassOf sc:Organization ;
    owl:disjointWith sc:Grower,
        sc:Retailer .

sc:Retailer a owl:Class ;
    rdfs:subClassOf sc:Organization ;
    owl:disjointWith sc:Grower,
        sc:LogisticsProvider .

sc:Facility a owl:Class ;
    rdfs:subClassOf sc:Entity ;
    owl:disjointWith sc:MaterialLot,
        sc:Organization,
        sc:Shipment .

sc:Organization a owl:Class ;
    rdfs:subClassOf sc:Entity ;
    owl:disjointWith sc:Facility,
        sc:MaterialLot,
        sc:Shipment .

